# AsyncOps API — environment variables

# HTTP
PORT=4000
# Comma-separated list of allowed origins for the dashboard. Leave unset or
# set to nothing for permissive CORS in dev.
CORS_ORIGIN=https://app.asyncops.com,https://asyncops.com

# MongoDB (hosted — e.g. MongoDB Atlas)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_DB=asyncops

# Redis (hosted — e.g. Upstash, Render, Railway)
REDIS_URL=rediss://default:pass@host:6379

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Queue tuning (optional)
MAX_JOB_ATTEMPTS=3
JOB_BACKOFF_DELAY_MS=2000
JOB_LOCK_DURATION_MS=600000
QUEUE_CONCURRENCY=500
